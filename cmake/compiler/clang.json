{
    "version": 7,
    "configurePresets": [
        {
            "name": "compiler-clang",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_FLAGS": "-Wall -Wextra -Werror -pedantic"
            }
        }
    ]
}